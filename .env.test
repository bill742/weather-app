# Placeholder API endpoints used only by the Playwright e2e suite.
# No real key is needed — every network call is mocked via page.route(),
# so these hosts are never actually contacted. Loaded by `vite --mode test`.
VITE_OPENWEATHER_API_URL=https://api.weather.test/data/2.5/weather
VITE_OPENWEATHER_GEO_URL=https://api.weather.test/geo/1.0
VITE_OPENWEATHER_API_KEY=test-key
VITE_SITE_URL=http://localhost:5173/
